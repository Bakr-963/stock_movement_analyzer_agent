# LLM provider
# Options: ollama, lmstudio
LLM_PROVIDER=ollama

# Model name in Ollama or LMStudio
LOCAL_LLM=gemma4:e4b-it-q8_0

# Endpoint for Ollama
# When running inside Docker on Docker Desktop, use http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434

# Endpoint for LMStudio's OpenAI-compatible server
# When running inside Docker on Docker Desktop, use http://host.docker.internal:1234/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Required for Tavily web search
TAVILY_API_KEY=tvly-your-key-here

# Research controls
MAX_RESEARCH_LOOPS=3
CONFIDENCE_THRESHOLD=80
SEARCH_MAX_RESULTS=5
MAX_TOKENS_PER_SOURCE=1000

# Optional runtime tuning
MODEL_TEMPERATURE=0
LOG_LEVEL=INFO